# --- Тестируемый API -------------------------------------------------------
BOOKSHELF_URL=https://qahacking.up.railway.app

# ===========================================================================
#  Модель для триажа — ЛЮБОЙ OpenAI-совместимый провайдер.
#  Выберите один блок ниже (раскомментируйте нужный) или впишите свой.
#  Ключ: DEEPSEEK_API_KEY или LLM_API_KEY; для локальных моделей — заглушка.
# ===========================================================================

# --- DeepSeek (по умолчанию) ------------------------------------------------
# Ключ: https://platform.deepseek.com
DEEPSEEK_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash        # типовые падения
LLM_MODEL_HARD=deepseek-v4-pro     # спорные (--escalate): переспросить умной моделью

# --- OpenAI -----------------------------------------------------------------
# LLM_API_KEY=sk-...
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
# LLM_MODEL_HARD=gpt-4o

# --- OpenRouter (много моделей за одним ключом) -----------------------------
# LLM_API_KEY=sk-or-...
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=deepseek/deepseek-chat
# LLM_MODEL_HARD=anthropic/claude-3.5-sonnet

# --- Ollama (локально, без облака) ------------------------------------------
# ollama pull qwen2.5:7b   →   сервер сам поднимется на :11434
# LLM_API_KEY=ollama                 # заглушка, локальному серверу ключ не нужен
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=qwen2.5:7b
# LLM_MODEL_HARD=qwen2.5:14b

# --- LM Studio (локально) ---------------------------------------------------
# LLM_API_KEY=lmstudio
# LLM_BASE_URL=http://localhost:1234/v1
# LLM_MODEL=<имя загруженной в LM Studio модели>

# Верхний лимит токенов на вердикт (JSON не должен обрезаться)
# LLM_MAX_TOKENS=1800

# --- Прочее ----------------------------------------------------------------
# Куда заводить черновики багов (по умолчанию — трекер тренажёра)
# ISSUES_URL=https://qahacking.up.railway.app/issues
